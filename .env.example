# Local Docker Mongo (default for offline / no Atlas whitelist)
MONGODB_URI=mongodb://127.0.0.1:27017/shipments

# Or MongoDB Atlas (whitelist your IP in Atlas → Network Access first):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/shipments

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
PORT=3000
NODE_ENV=development
RATE_LIMIT_PER_MINUTE=10000
BATCH_SIZE=500
