MONGODB_URI=mongodb://127.0.0.1:27017/shipments

# Production / Atlas (whitelist server IP in Atlas Network Access first):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/shipments?retryWrites=true&w=majority

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
PORT=3000
NODE_ENV=development
RATE_LIMIT_PER_MINUTE=10000
BATCH_SIZE=500
# 1 = process queue jobs one-by-one (best for live queue demo)
WORKER_CONCURRENCY=1

# Single-domain production: leave VITE_API_URL unset when building
# so the UI calls /api/v1 on the same host.
# Only set this if API is on a different domain:
# VITE_API_URL=https://api.example.com/api/v1
